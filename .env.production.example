# Never keep placeholder values in production. Generate strong random secrets.
POSTGRES_DB=construction_erp_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_strong_db_password_min_24_chars

JWT_SECRET=replace_with_strong_jwt_secret_min_32_chars
ONBOARDING_BOOTSTRAP_SECRET=replace_with_strong_bootstrap_secret_min_24_chars
PLATFORM_OWNER_COMPANY_ID=

# Use your real HTTPS domain in production.
CORS_ORIGIN=https://erp.your-domain.com
# Bind web container to localhost and let host-level Caddy/Nginx terminate TLS.
WEB_BIND_IP=127.0.0.1
WEB_PORT=8080
LOG_LEVEL=info
TRUST_PROXY_HOPS=1
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000

# Current backend implementation uses postgres-backed rate limiting.
RATE_LIMIT_STORE=postgres
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14

LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=900000
PASSWORD_RESET_RATE_LIMIT_MAX_ATTEMPTS=5
ONBOARDING_RATE_LIMIT_WINDOW_MS=900000
ONBOARDING_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_REFRESH_RATE_LIMIT_WINDOW_MS=300000
AUTH_REFRESH_RATE_LIMIT_MAX_ATTEMPTS=20
PASSWORD_RESET_TOKEN_TTL_MINUTES=15
EXPOSE_PASSWORD_RESET_TOKEN=false

VITE_API_BASE_URL=/api
ENFORCE_COMPANY_SCOPE=true

# Optional offsite backup settings (leave disabled if not configured)
OFFSITE_BACKUP_ENABLED=false
OFFSITE_BACKUP_PROVIDER=
OFFSITE_BACKUP_S3_URI=
OFFSITE_BACKUP_RCLONE_REMOTE=
