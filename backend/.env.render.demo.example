# Render backend demo env template (free-tier)
NODE_ENV=production
PORT=10000
LOG_LEVEL=info

# Must be your Vercel URL(s), comma-separated if multiple
CORS_ORIGIN=https://your-frontend.vercel.app

ENFORCE_COMPANY_SCOPE=true
EXPOSE_PASSWORD_RESET_TOKEN=false
# Industrial-grade production default:
# deliver reset requests to your own service instead of returning tokens in API responses.
PASSWORD_RESET_DELIVERY_MODE=webhook
PASSWORD_RESET_WEBHOOK_URL=https://your-reset-handler.example.com/webhook
PASSWORD_RESET_PUBLIC_RESET_BASE_URL=https://your-frontend.vercel.app/forgot-password
PASSWORD_RESET_DELIVERY_CHANNELS=mobile,email
PASSWORD_RESET_DELIVERY_SUCCESS_POLICY=any

# Strong secrets (Render can generate)
JWT_SECRET=replace_with_min_32_char_secret
ONBOARDING_BOOTSTRAP_SECRET=replace_with_min_24_char_secret

# Keep this aligned with owner company id in your DB
PLATFORM_OWNER_COMPANY_ID=1

# Render Postgres values (autofill from Render DB connection)
DB_HOST=replace_from_render_db_host
DB_PORT=5432
DB_NAME=construction_erp_db
DB_USER=replace_from_render_db_user
DB_PASSWORD=replace_from_render_db_password

# Optional pool tuning for free tier
DB_POOL_MAX=10
DB_POOL_MIN=1
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
