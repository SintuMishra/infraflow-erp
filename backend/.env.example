PORT=5000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
ENFORCE_COMPANY_SCOPE=true
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=900000
PASSWORD_RESET_RATE_LIMIT_MAX_ATTEMPTS=5
ONBOARDING_RATE_LIMIT_WINDOW_MS=900000
ONBOARDING_RATE_LIMIT_MAX_ATTEMPTS=10
PASSWORD_RESET_TOKEN_TTL_MINUTES=15
EXPOSE_PASSWORD_RESET_TOKEN=true
ONBOARDING_BOOTSTRAP_SECRET=replace_with_a_long_random_bootstrap_secret
PLATFORM_OWNER_COMPANY_ID=1
JWT_SECRET=replace_with_a_long_random_secret
DB_HOST=localhost
DB_PORT=5432
DB_NAME=construction_erp_db
DB_USER=postgres
DB_PASSWORD=replace_with_secure_password

# Optional smoke automation variables (for scripts/final-prelive-check.sh advanced owner governance step):
# SMOKE_BASE_URL=http://127.0.0.1:5001/api
# SMOKE_BOOTSTRAP_SECRET=replace_with_same_as_onboarding_bootstrap_secret
# SMOKE_ADMIN_USERNAME=owner_admin_username
# SMOKE_ADMIN_PASSWORD=owner_admin_password
# SMOKE_ADMIN_COMPANY_ID=1

# This file is for local development defaults.
# For production deploy, copy from backend/.env.production.example and use real domain secrets.

# Production security expectations:
# - CORS_ORIGIN must not be *
# - CORS_ORIGIN must not include localhost or 127.0.0.1
# - JWT_SECRET must be non-placeholder and at least 32 chars
# - ONBOARDING_BOOTSTRAP_SECRET (if set) must be non-placeholder and at least 24 chars
